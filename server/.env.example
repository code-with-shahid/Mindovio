# Mindovio server environment
PORT=8000
MONGODB_URL=mongodb://127.0.0.1:27017/mindovio
JWT_SECRET=your_jwt_secret
GEMINI_API_KEY=your_gemini_api_key

# Preferred: comma-separated fallback chain (tried in order)
# GEMINI_MODELS=gemini-3.5-flash,gemini-2.0-flash,gemini-flash-latest
# Or set individually:
# GEMINI_MODEL=gemini-3.5-flash
# GEMINI_FALLBACK_MODEL=gemini-2.0-flash
# GEMINI_FALLBACK_MODEL_2=gemini-flash-latest

STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
CLIENT_URL=http://localhost:5173

# Admin Panel (server-only — never expose to Vite/client)
ADMIN_EMAIL=admin@mindovio.com
ADMIN_PASSWORD=use_a_strong_secret
ADMIN_JWT_SECRET=separate_from_jwt_secret
ADMIN_SESSION_HOURS=8
