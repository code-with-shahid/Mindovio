# Mindovio server environment
PORT=8000
NODE_ENV=development
# On Render set: NODE_ENV=production
# Secure cross-site cookies also enable automatically when CLIENT_URL starts with https://

MONGODB_URL=mongodb://127.0.0.1:27017/mindovio
JWT_SECRET=your_jwt_secret
GEMINI_API_KEY=your_gemini_api_key

# Preferred: comma-separated fallback chain (tried in order)
# gemini-2.0-flash is shut down — use 3.5 / 2.5 family
GEMINI_MODELS=gemini-3.5-flash,gemini-2.5-flash,gemini-2.5-flash-lite,gemini-flash-latest

# Stripe TEST MODE (free sandbox — use sk_test_… keys only for now)
STRIPE_SECRET_KEY=sk_test_your_test_secret_key
# Optional until you create a Dashboard/CLI webhook; credits also confirm via /api/credit/confirm
STRIPE_WEBHOOK_SECRET=whsec_your_test_webhook_secret

# Deployed frontend (Firebase) + local Vite
CLIENT_URL=https://authexamnotes-f0c26.web.app
CORS_ORIGINS=https://authexamnotes-f0c26.web.app,https://authexamnotes-f0c26.firebaseapp.com,http://localhost:5173,http://localhost:5174

# Admin Panel (server-only — never expose to Vite/client)
ADMIN_EMAIL=admin@mindovio.com
ADMIN_PASSWORD=use_a_strong_secret
ADMIN_JWT_SECRET=separate_from_jwt_secret
ADMIN_SESSION_HOURS=8
